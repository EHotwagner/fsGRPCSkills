<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <RestoreSuccess Condition=" '$(RestoreSuccess)' == '' ">True</RestoreSuccess>
    <RestoreTool Condition=" '$(RestoreTool)' == '' ">NuGet</RestoreTool>
    <ProjectAssetsFile Condition=" '$(ProjectAssetsFile)' == '' ">$(MSBuildThisFileDirectory)project.assets.json</ProjectAssetsFile>
    <NuGetPackageRoot Condition=" '$(NuGetPackageRoot)' == '' ">/home/developer/.nuget/packages/</NuGetPackageRoot>
    <NuGetPackageFolders Condition=" '$(NuGetPackageFolders)' == '' ">/home/developer/.nuget/packages/</NuGetPackageFolders>
    <NuGetProjectStyle Condition=" '$(NuGetProjectStyle)' == '' ">PackageReference</NuGetProjectStyle>
    <NuGetToolVersion Condition=" '$(NuGetToolVersion)' == '' ">7.0.0</NuGetToolVersion>
  </PropertyGroup>
  <ItemGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <SourceRoot Include="/home/developer/.nuget/packages/" />
  </ItemGroup>
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)xunit.runner.visualstudio/3.0.1/build/net6.0/xunit.runner.visualstudio.props" Condition="Exists('$(NuGetPackageRoot)xunit.runner.visualstudio/3.0.1/build/net6.0/xunit.runner.visualstudio.props')" />
    <Import Project="$(NuGetPackageRoot)xunit.core/2.9.3/build/xunit.core.props" Condition="Exists('$(NuGetPackageRoot)xunit.core/2.9.3/build/xunit.core.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testplatform.testhost/17.12.0/build/netcoreapp3.1/Microsoft.TestPlatform.TestHost.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testplatform.testhost/17.12.0/build/netcoreapp3.1/Microsoft.TestPlatform.TestHost.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.codecoverage/17.12.0/build/netstandard2.0/Microsoft.CodeCoverage.props" Condition="Exists('$(NuGetPackageRoot)microsoft.codecoverage/17.12.0/build/netstandard2.0/Microsoft.CodeCoverage.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.net.test.sdk/17.12.0/build/netcoreapp3.1/Microsoft.NET.Test.Sdk.props" Condition="Exists('$(NuGetPackageRoot)microsoft.net.test.sdk/17.12.0/build/netcoreapp3.1/Microsoft.NET.Test.Sdk.props')" />
  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Pkgxunit_runner_visualstudio Condition=" '$(Pkgxunit_runner_visualstudio)' == '' ">/home/developer/.nuget/packages/xunit.runner.visualstudio/3.0.1</Pkgxunit_runner_visualstudio>
    <Pkgxunit_analyzers Condition=" '$(Pkgxunit_analyzers)' == '' ">/home/developer/.nuget/packages/xunit.analyzers/1.18.0</Pkgxunit_analyzers>
    <Pkgxunit Condition=" '$(Pkgxunit)' == '' ">/home/developer/.nuget/packages/xunit/2.9.3</Pkgxunit>
    <PkgSystem_ServiceModel_Primitives Condition=" '$(PkgSystem_ServiceModel_Primitives)' == '' ">/home/developer/.nuget/packages/system.servicemodel.primitives/8.1.0</PkgSystem_ServiceModel_Primitives>
    <Pkgprotobuf-net Condition=" '$(Pkgprotobuf-net)' == '' ">/home/developer/.nuget/packages/protobuf-net/3.2.45</Pkgprotobuf-net>
    <Pkgprotobuf-net_Grpc Condition=" '$(Pkgprotobuf-net_Grpc)' == '' ">/home/developer/.nuget/packages/protobuf-net.grpc/1.1.1</Pkgprotobuf-net_Grpc>
    <Pkgprotobuf-net_Grpc_Native Condition=" '$(Pkgprotobuf-net_Grpc_Native)' == '' ">/home/developer/.nuget/packages/protobuf-net.grpc.native/1.1.1</Pkgprotobuf-net_Grpc_Native>
    <Pkgprotobuf-net_Grpc_AspNetCore Condition=" '$(Pkgprotobuf-net_Grpc_AspNetCore)' == '' ">/home/developer/.nuget/packages/protobuf-net.grpc.aspnetcore/1.1.1</Pkgprotobuf-net_Grpc_AspNetCore>
    <PkgFSharp_Core Condition=" '$(PkgFSharp_Core)' == '' ">/home/developer/.nuget/packages/fsharp.core/10.0.103</PkgFSharp_Core>
    <Pkgprotobuf-net-fsharp Condition=" '$(Pkgprotobuf-net-fsharp)' == '' ">/home/developer/.nuget/packages/protobuf-net-fsharp/0.1.0</Pkgprotobuf-net-fsharp>
    <PkgMicrosoft_NET_Test_Sdk Condition=" '$(PkgMicrosoft_NET_Test_Sdk)' == '' ">/home/developer/.nuget/packages/microsoft.net.test.sdk/17.12.0</PkgMicrosoft_NET_Test_Sdk>
    <PkgMicrosoft_AspNetCore_TestHost Condition=" '$(PkgMicrosoft_AspNetCore_TestHost)' == '' ">/home/developer/.nuget/packages/microsoft.aspnetcore.testhost/9.0.0</PkgMicrosoft_AspNetCore_TestHost>
    <PkgGrpc_Net_Client Condition=" '$(PkgGrpc_Net_Client)' == '' ">/home/developer/.nuget/packages/grpc.net.client/2.67.0</PkgGrpc_Net_Client>
  </PropertyGroup>
</Project>